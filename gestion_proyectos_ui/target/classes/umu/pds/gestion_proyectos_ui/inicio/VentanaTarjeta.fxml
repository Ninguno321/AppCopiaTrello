<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox fx:id="root" styleClass="tarjeta" stylesheets="@../estilos/theme.css, @../estilos/app-base2.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaTarjetaController">
   <children>
      <CheckBox fx:id="check" mnemonicParsing="false" prefHeight="25.0" prefWidth="26.0" />
      <VBox spacing="4.0" HBox.hgrow="ALWAYS">
         <children>
            <FlowPane fx:id="contenedorEtiquetas" hgap="4.0" vgap="4.0">
               <VBox.margin>
                  <Insets left="6.0" top="2.0" />
               </VBox.margin>
            </FlowPane>
            
            <Text fx:id="tituloTarjeta" text="Tarjeta de prueba">
               <VBox.margin>
                  <Insets left="6.0" />
               </VBox.margin>
            </Text>
            
            <VBox fx:id="contenedorItems" managed="false" visible="false">
               <VBox.margin>
                  <Insets left="6.0" top="4.0" />
               </VBox.margin>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" spacing="6.0">
               <VBox.margin>
                  <Insets bottom="2.0" left="6.0" top="4.0" />
               </VBox.margin>
               <Button fx:id="btnAnadirEtiqueta" onAction="#onAnadirEtiquetaClick" style="-fx-font-size: 9px; -fx-padding: 2 4;" styleClass="boton-etiqueta" text="+ Etiqueta" />
               <DatePicker fx:id="datePickerVencimiento" prefHeight="19.0" prefWidth="91.0" promptText="Vencimiento" style="-fx-font-size: 9px;" styleClass="date-picker-tarjeta" />
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>
