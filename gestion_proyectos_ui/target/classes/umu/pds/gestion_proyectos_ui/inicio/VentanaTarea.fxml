<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>

<HBox fx:id="root" styleClass="tarjeta" stylesheets="@../estilos/theme.css, @../estilos/app-base2.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaTarjetaController">
   <children>
      <CheckBox fx:id="check" mnemonicParsing="false" />
      <Text fx:id="textoTarea" text="Tarjeta de prueba">
         <HBox.margin>
            <Insets left="6.0" />
         </HBox.margin>
      </Text>
   </children>
</HBox>