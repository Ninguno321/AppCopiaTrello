<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane styleClass="root" stylesheets="@../estilos/theme.css, @/umu/pds/gestion_proyectos_ui/estilos/app-base.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaInicioController">

    <VBox alignment="CENTER" prefHeight="717.0" prefWidth="1330.0" spacing="30">
        <VBox alignment="CENTER" spacing="10">

		<StackPane maxHeight="70.0" maxWidth="70.0" prefHeight="70.0" prefWidth="70.0" styleClass="logo-box">

    		<SVGPath content="M3 3h18v18H3z M3 9h18 M9 9v12" styleClass="logo-icon" />
		</StackPane>

            <Label styleClass="title" text="Mistableros.com" />

            <Label styleClass="subtitle" text="Crea tableros y organiza tus tareas" wrapText="true" />

        </VBox>
        <VBox alignment="TOP_LEFT" maxWidth="420" spacing="15" styleClass="card">

            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <Label styleClass="card-title" text="Crear tablero" />

            <VBox spacing="5">
                <Label text="Nombre del tablero" />
                <TextField fx:id="txtNombreTablero" promptText="Mi proyecto..." />
            </VBox>

            <VBox spacing="5">
                <Label text="Tu correo electrónico" />
                <TextField fx:id="txtEmail" promptText="nombre@ejemplo.com" />
            </VBox>

            <Button fx:id="btnCrearTablero" maxWidth="Infinity" onAction="#onCrearTablero" styleClass="primary-button" text="Crear tablero" />

        </VBox>

        <HBox alignment="CENTER" spacing="15">
            <Label styleClass="footer-text" text="Simple" />
            <Label styleClass="footer-text" text="•" />
            <Label styleClass="footer-text" text="Fast" />
            <Label styleClass="footer-text" text="•" />
            <Label styleClass="footer-text" text="Collaborative" />
        </HBox>

    </VBox>

</StackPane>
