<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1000.0" prefWidth="1333.0" stylesheets="@../estilos/theme.css, @../estilos/app-base.css, @../estilos/app-board.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaPrincipalController">

   <left>
      <VBox prefWidth="220.0" spacing="4.0" styleClass="sidebar">
         <padding>
            <Insets bottom="16.0" left="12.0" right="12.0" top="20.0" />
         </padding>

         <Label styleClass="sidebar-section-title" text="Mis tableros" />

         <VBox fx:id="sidebarTableros" spacing="4.0" />

         <Button fx:id="btnCrearTablero" maxWidth="Infinity" onAction="#onCrearTablero" styleClass="sidebar-create" text="+ Crear tablero" />

         <Button fx:id="btnImportarPlantilla" maxWidth="Infinity" onAction="#onImportarPlantillaClick" styleClass="sidebar-create" text="+ Importar Plantilla" />

         <Region VBox.vgrow="ALWAYS" />

         <Button fx:id="btnConfiguracion" maxWidth="Infinity" onAction="#onConfiguracion" styleClass="sidebar-config" text="⚙  Configuración" />
      </VBox>
   </left>

   <center>
      <VBox spacing="12.0" styleClass="content-area">
         <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
         </padding>

         <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="content-header">
            <Label fx:id="lblTableroActual" styleClass="content-title" text="Tablero 1" />
            <Button fx:id="TableroID" alignment="CENTER" contentDisplay="CENTER" onMouseClicked="#onCopiarTableroId" prefHeight="25.0" prefWidth="88.0" styleClass="tablero-id-btn" text="Tablero_id" textAlignment="CENTER">
               <font>
                  <Font size="15.0" />
               </font>
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </Button>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAutomatizaciones" onAction="#onAutomatizaciones" styleClass="btn-automatizaciones" text="Automatizaciones" />
            <Button fx:id="btnChatAi" onAction="#onChatAi" styleClass="btn-automatizaciones" text="ChatAI" />
         </HBox>

         <HBox spacing="4.0" styleClass="toolbar-box">
            <Button fx:id="btnTabTablero" onAction="#onTabTablero" styleClass="button,active" text="Tablero" />
            <Button fx:id="btnTabCalendario" onAction="#onTabCalendario" styleClass="button" text="Calendario" />
            <Button fx:id="btnTabTabla" onAction="#onTabTabla" styleClass="button" text="Tabla" />
         </HBox>

         <StackPane fx:id="mainContentPane" styleClass="main-content-pane" VBox.vgrow="ALWAYS" />
      </VBox>
   </center>

</BorderPane>
