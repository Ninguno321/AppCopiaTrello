<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="1000.0" stylesheets="@../estilos/theme.css, @../estilos/app-board.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaTableroController">
   <children>

      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <TextField promptText="Buscar" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnBloquear" mnemonicParsing="false" onAction="#toggleBloqueo" styleClass="button" text="Bloquear" />
            <Button mnemonicParsing="false" onAction="#verHistorial" styleClass="button" text="Ver Historial" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>

      <!-- Zona de eliminación -->
      <HBox fx:id="zonaEliminar" alignment="CENTER" managed="false" minHeight="50.0" prefHeight="50.0" styleClass="zona-eliminar" visible="false">
         <children>
            <Label styleClass="zona-eliminar-texto" text="Arrastra aquí para eliminar" />
         </children>
         <padding>
            <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
         </padding>
      </HBox>

      <!-- Contenido scrollable, sin barra nativa -->
      <ScrollPane fx:id="scrollTablero" fitToHeight="false" hbarPolicy="NEVER" prefHeight="254.0" prefWidth="1000.0" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
         <content>
			<HBox fx:id="contenedorListas" alignment="TOP_LEFT" fillHeight="false" spacing="15.0">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </HBox>
         </content>
      </ScrollPane>

      <!-- Botones fijos -->
      <HBox alignment="CENTER" prefHeight="0.0" prefWidth="1000.0" spacing="5.0">
         <children>
            <VBox prefHeight="45.0" prefWidth="559.0" styleClass="toolbar-box">
               <children>
                  <HBox alignment="TOP_CENTER" prefHeight="33.0" prefWidth="492.0">
                     <children>
                        <Button mnemonicParsing="false" styleClass="button" text="Bandeja de entrada" />
                        <Button mnemonicParsing="false" styleClass="button" text="Planificador" />
                        <Button mnemonicParsing="false" styleClass="button,active" text="Tablero" />
                        <Button fx:id="btnCrearLista" mnemonicParsing="false" onMouseClicked="#crearLista" styleClass="button" text="+ Añadir lista" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="9.0" top="10.0" />
         </padding>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </HBox>

      <!-- Scrollbar manual, debajo de los botones -->
      <ScrollBar fx:id="scrollBarH" blockIncrement="0.1" max="1.0" min="0.0" orientation="HORIZONTAL" styleClass="lista-scroll" unitIncrement="0.05" value="0.0">
         <VBox.margin>
            <Insets bottom="1.0" />
         </VBox.margin>
         <padding>
            <Insets bottom="8.0" />
         </padding></ScrollBar>

   </children>
</VBox>
