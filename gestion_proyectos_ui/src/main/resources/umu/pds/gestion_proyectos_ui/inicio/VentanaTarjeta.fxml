<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox fx:id="root" styleClass="tarjeta" stylesheets="@../estilos/theme.css, @../estilos/app-base2.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="umu.pds.gestion_proyectos_ui.inicio.VentanaTarjetaController">
   <children>
      <CheckBox fx:id="check" mnemonicParsing="false" />
      <VBox HBox.hgrow="ALWAYS">
         <children>
            <Text fx:id="tituloTarjeta" text="Tarjeta de prueba">
               <VBox.margin>
                  <Insets left="6.0" />
               </VBox.margin>
            </Text>
            <VBox fx:id="contenedorItems" visible="false" managed="false">
               <VBox.margin>
                  <Insets left="6.0" top="4.0" />
               </VBox.margin>
            </VBox>
         </children>
      </VBox>
   </children>
</HBox>
